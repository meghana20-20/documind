# Choose one: openai | anthropic | ollama
LLM_PROVIDER=ollama

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required if LLM_PROVIDER=ollama (ollama must be running locally: `ollama serve`)
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://localhost:11434
